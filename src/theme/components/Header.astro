---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  siteName?: string;
  navItems?: NavItem[];
}

const {
  siteName = "NocturnalZone",
  navItems = [
    { href: "/", label: "Home" },
    { href: "/blog", label: "Blog" },
    { href: "/components", label: "Components" },
    { href: "/pricing", label: "Pricing" },
    { href: "/directory", label: "Directory" },
  ],
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="nz-header">
  <div class="nz-header__inner nz-container">
    <a class="nz-brand" href="/">{siteName}</a>
    <nav class="nz-nav" aria-label="Primary navigation">
      {navItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, "") || "/";
        const isCurrent = currentPath === itemPath;
        return (
          <a class="nz-nav__link" href={item.href} aria-current={isCurrent ? "page" : undefined}>
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
